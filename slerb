  tmp="$(mktemp)"

  awk -F'\t' -v OFS='\t' \
    -v id="$job_id" -v st="$status" -v ec="$exit_code" \
    -v tgt="$target" -v start="$start_time" -v et="$end_time" \
    -v rd="$remote_dir" -v gpu="$gpu_id" '
