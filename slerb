fetch_job() {
  local job_id="$1" force_clean="${2:-no}"
  local status exit_code node target start_time end_time local_dir remote_dir keep input_dir run_script gpu_id array_range array_task array_id
  local line

  line="$(awk -F'\t' -v id="$job_id" '$1 == id {print; found=1} END {if (!found) exit 1}' "$JOBS_FILE")" || {
    err "Unknown job_id: $job_id"
    return 1
  }

  IFS=$'\t' read -r job_id status exit_code node target start_time end_time local_dir remote_dir keep input_dir run_script gpu_id array_range array_task array_id <<< "$line"

  if [[ -z "$remote_dir" || "$remote_dir" == "-" ]]; then
    err "No remote directory recorded for $job_id"
    return 1
  fi

  local remote_ec rc

  set +e
  remote_ec="$(remote_job_done_check "$target" "$remote_dir" 2>/dev/null)"
  rc=$?
  set -e

  if [[ $rc -eq 75 ]]; then
    history_update "$job_id" "RUNNING" "-" "-"
    log_msg "$job_id still running; not fetching partial results"
    return 75
  elif [[ $rc -eq 76 ]]; then
    history_update "$job_id" "MISSING" "-" "$(date '+%Y-%m-%d %H:%M:%S')"
    err "$job_id remote directory is missing"
    return 76
  elif [[ $rc -ne 0 ]]; then
    err "Could not check remote job status for $job_id"
    return "$rc"
  fi

  remote_ec="$(trim "$remote_ec")"

  log_msg "Fetching $job_id from $node"
  rsync_from_remote "$target" "$remote_dir" "$local_dir"

  if [[ "$remote_ec" == "CANCELED" ]]; then
    history_update "$job_id" "CANCELED" "130" \
      "$(date '+%Y-%m-%d %H:%M:%S')"
  elif [[ "$remote_ec" == "0" ]]; then
    history_update "$job_id" "DONE" "$remote_ec" "$(date '+%Y-%m-%d %H:%M:%S')"
  else
    history_update "$job_id" "FAILED" "$remote_ec" "$(date '+%Y-%m-%d %H:%M:%S')"
  fi

  if [[ "$force_clean" == "yes" || ( "$keep" != "yes" && "$remote_ec" == "0" ) ]]; then
    log_msg "Cleaning remote job directory for $job_id"
    remote_cleanup_job "$target" "$remote_dir"
  fi

  printf '%s\n' "$local_dir"
}

cancel_job() {
  local job_id="$1"
  local line status exit_code node target start_time end_time
  local local_dir remote_dir keep input_dir run_script gpu_id
  local array_range array_task array_id rc cancel_out

  line="$(awk -F'\t' -v id="$job_id" '
    $1 == id {print; found=1} END {if (!found) exit 1}
  ' "$JOBS_FILE")" || {
    err "Unknown job_id: $job_id"
    return 1
  }

  IFS=$'\t' read -r job_id status exit_code node target start_time \
    end_time local_dir remote_dir keep input_dir run_script gpu_id \
    array_range array_task array_id <<< "$line"

  if [[ -z "$remote_dir" || "$remote_dir" == "-" ]]; then
    if [[ "$status" == "QUEUED" || "$status" == "DISPATCHING" ]]; then
      local spool_dir
      spool_dir="$(queue_spool_dir "$job_id")"
      queue_remove_job "$job_id"
      [[ -n "$spool_dir" ]] && rm -rf "$spool_dir"
      history_update "$job_id" "CANCELED" "130"         "$(date '+%Y-%m-%d %H:%M:%S')"
      log_msg "Canceled queued job $job_id"
      return 0
    fi

    err "No remote directory recorded for $job_id"
    return 1
  fi

  set +e
  cancel_out="$(remote_cancel_job "$target" "$remote_dir" 2>&1)"
  rc=$?
  set -e

  if [[ $rc -eq 0 ]]; then
    history_update "$job_id" "CANCELED" "130" \
      "$(date '+%Y-%m-%d %H:%M:%S')"
    log_msg "Canceled $job_id on $node"
    return 0
  fi

  if [[ $rc -eq 76 ]]; then
    history_update "$job_id" "MISSING" "-" \
      "$(date '+%Y-%m-%d %H:%M:%S')"
    err "$job_id remote directory is missing"
    return 76
  fi

  err "Could not cancel $job_id: $cancel_out"
  return "$rc"
}

