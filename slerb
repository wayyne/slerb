  ' "$JOBS_FILE")" || {
    err "Unknown job_id: $job_id"
    return 1
  }

  IFS=$'\t' read -r job_id status exit_code node target start_time \
    end_time local_dir remote_dir keep input_dir run_script gpu_id \
    array_range array_task array_id <<< "$line"

  array_range="${array_range:--}"
  array_task="${array_task:--}"
  array_id="${array_id:--}"

  if [[ -z "$gpu_id" || "$gpu_id" == "-" ]]; then
    err "No GPU recorded for $job_id; cannot restart"
    return 1
  fi

  local gpu_ids gpu_count
  gpu_ids="$(normalize_gpu_list "$gpu_id")" || {
    err "Recorded GPU for $job_id is not a physical GPU index list: $gpu_id"
    return 1
  }
  gpu_count="$(csv_count "$gpu_ids")"

  local node_line name user host env_file tags

  if ! node_line="$(get_node "$node")"; then
    err "Unknown node in job history for $job_id: $node"
    return 1
  fi

  IFS=$'\t' read -r name user host env_file tags <<< "$node_line"
  env_file="${env_file:-$DEFAULT_ENV_FILE}"
  target="$(ssh_target "$user" "$host")"

  local prepare_out setup_out rc work_dir

  set +e
  prepare_out="$(remote_prepare_restart \
    "$target" "$env_file" "$remote_dir" "$job_id" "$gpu_ids" "$force" 2>&1)"
  rc=$?
  set -e

  if [[ $rc -eq 0 ]]; then
    remote_dir="$(printf '%s\n' "$prepare_out" | kv_get REMOTE_DIR)"
    work_dir="$(printf '%s\n' "$prepare_out" | kv_get WORK_DIR)"
    gpu_ids="$(printf '%s\n' "$prepare_out" | kv_get GPU_IDS)"
    gpu_ids="${gpu_ids:-$(printf '%s\n' "$prepare_out" | kv_get GPU_ID)}"
  elif [[ $rc -eq 76 || $rc -eq 78 ]]; then
    [[ -d "$input_dir" ]] || {
      err "Cannot restage $job_id; input_dir is missing: $input_dir"
      return 1
    }

    [[ -f "$run_script" ]] || {
      err "Cannot restage $job_id; run_script is missing: $run_script"
      return 1
    }

    if [[ $rc -eq 78 && -n "$remote_dir" && "$remote_dir" != "-" ]]; then
      remote_abort_job "$target" "$env_file" "$remote_dir"
    fi

    set +e
    setup_out="$(remote_setup_job \
      "$target" "$env_file" "$job_id" "$gpu_ids" "$gpu_count" 2>&1)"
    rc=$?
    set -e

    if [[ $rc -ne 0 ]]; then
      err "Remote restart setup failed for $job_id on $node: $setup_out"
      return "$rc"
    fi

    remote_dir="$(printf '%s\n' "$setup_out" | kv_get REMOTE_DIR)"
    work_dir="$(printf '%s\n' "$setup_out" | kv_get WORK_DIR)"
    gpu_ids="$(printf '%s\n' "$setup_out" | kv_get GPU_IDS)"
    gpu_ids="${gpu_ids:-$(printf '%s\n' "$setup_out" | kv_get GPU_ID)}"

    log_msg "Restaging $job_id to $node GPU(s) $gpu_ids"

    set +e
    rsync_to_remote "$input_dir/" "$target" "$work_dir/"
    rc=$?

    if [[ $rc -eq 0 ]]; then
      rsync -azcL "$run_script" "$target:$work_dir/run.sh"
      rc=$?
    fi
    set -e

    if [[ $rc -ne 0 ]]; then
      remote_abort_job "$target" "$env_file" "$remote_dir"
      err "Restart staging failed for $job_id"
      return "$rc"
    fi
  else
    err "Could not prepare restart for $job_id on $node: $prepare_out"
    return "$rc"
  fi

  set +e
  prepare_out="$(remote_run_detached \
    "$target" "$env_file" "$remote_dir" "$gpu_ids" "$job_id" \
    "$array_task" "$array_range" "$array_id" 2>&1)"
  rc=$?
  set -e

  if [[ $rc -ne 0 ]]; then
    err "Could not relaunch $job_id on $node: $prepare_out"
    return "$rc"
  fi

  history_restart_update "$job_id" "DETACHED" "-" "$target" \
    "$(date '+%Y-%m-%d %H:%M:%S')" "-" "$remote_dir" "$gpu_ids"

  log_msg "Restarted detached: $job_id on $node GPU(s) $gpu_ids"
  printf '%s\n' "$job_id"
}

fetch_all_done() {
  local fetched=0 skipped=0 failed=0
  local job_id status target remote_dir remote_ec rc

  while IFS=$'\t' read -r job_id status _exit_code _node target _start _end _local remote_dir _keep _input _script _gpu _range _task _array; do
    [[ -z "${job_id:-}" ]] && continue

    case "$status" in
      DETACHED|RUNNING|STAGED) ;;
      *) continue ;;
    esac

    [[ -z "${remote_dir:-}" || "$remote_dir" == "-" ]] && continue

    set +e
    remote_ec="$(remote_job_done_check "$target" "$remote_dir" 2>/dev/null)"
    rc=$?
    set -e

    if [[ $rc -eq 0 ]]; then
      if fetch_job "$job_id" "no"; then
        fetched=$((fetched + 1))
      else
        failed=$((failed + 1))
      fi
    elif [[ $rc -eq 75 ]]; then
      skipped=$((skipped + 1))
    else
      log_msg "Skipping $job_id; status check failed or remote missing"
      failed=$((failed + 1))
    fi
  done < "$JOBS_FILE"

  log_msg "fetch --all-done complete: fetched=$fetched still_running=$skipped failed_checks=$failed"
}

show_log() {
  local job_id="$1"
  local local_dir remote_dir target

  local_dir="$(history_field "$job_id" 8)"
  target="$(history_field "$job_id" 5)"
  remote_dir="$(history_field "$job_id" 9)"

  if [[ -n "$local_dir" && -f "$local_dir/job.log" ]]; then
    cat "$local_dir/job.log"
  elif [[ -n "$target" && -n "$remote_dir" ]]; then
    ssh "${SSH_OPTS[@]}" "$target" "cat $(remote_quote "$remote_dir/job.log") 2>/dev/null || true"
  else
    err "Unknown job_id or no log found: $job_id"
    return 1
  fi
}

main() {
  local cmd="${1:-}"

  [[ -z "$cmd" ]] && {
    usage
    exit 1
  }

  shift || true

  case "$cmd" in
    status)
      status_all
      ;;

    validate)
      validate_nodes "${1:-$NODES_FILE}"
      ;;

    jobs)
      show_jobs "${1:-30}"
      ;;

    queue)
      show_queue
      ;;

    dispatch)
      local interval="$DISPATCH_INTERVAL"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --interval)
            interval="${2:?missing seconds after --interval}"
            shift 2
            ;;
          --help|-h)
            usage
            exit 0
            ;;
          *)
            usage
            exit 1
            ;;
        esac
      done

      dispatch_queue "$interval"
      ;;

    arrays)
      show_arrays
      ;;

    log)
      [[ $# -eq 1 ]] || {
        usage
        exit 1
      }

      show_log "$1"
      ;;

    cancel)
      [[ $# -eq 1 ]] || {
        usage
        exit 1
      }

      cancel_job "$1"
      ;;

    restart)
      local force="no"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --force)
            force="yes"
            shift
            ;;
          --help|-h)
            usage
            exit 0
            ;;
          *)
            break
            ;;
        esac
      done

      [[ $# -eq 1 ]] || {
        usage
        exit 1
      }

      restart_job "$1" "$force"
      ;;

    reserve)
      local node="${1:-}"
      local gpu_wanted="" reason="reserved"

      [[ -n "$node" ]] || {
        usage
        exit 1
      }
      shift

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --gpu)
            gpu_wanted="${2:?missing GPU id after --gpu}"
            shift 2
            ;;
          --reason)
            reason="${2:?missing text after --reason}"
            shift 2
            ;;
          --help|-h)
            usage
            exit 0
            ;;
          *)
            usage
            exit 1
            ;;
        esac
      done

      if [[ -n "$gpu_wanted" ]]; then
        [[ "$gpu_wanted" =~ ^[0-9]+$ ]] || {
          err "--gpu expects a physical GPU index"
          exit 1
        }
      fi

      reserve_resource "$node" "$gpu_wanted" "$reason"
      ;;

    release)
      local node="${1:-}"
      local gpu_wanted=""

      [[ -n "$node" ]] || {
        usage
        exit 1
      }
      shift

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --gpu)
            gpu_wanted="${2:?missing GPU id after --gpu}"
            shift 2
            ;;
          --help|-h)
            usage
            exit 0
            ;;
          *)
            usage
            exit 1
            ;;
        esac
      done

      if [[ -n "$gpu_wanted" ]]; then
        [[ "$gpu_wanted" =~ ^[0-9]+$ ]] || {
          err "--gpu expects a physical GPU index"
          exit 1
        }
      fi

      release_resource "$node" "$gpu_wanted"
      ;;

    fetch)
      local clean="no" all_done="no"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --clean)
            clean="yes"
            shift
            ;;
          --all-done)
            all_done="yes"
            shift
            ;;
          --help|-h)
            usage
            exit 0
            ;;
          *)
            break
            ;;
        esac
      done

      if [[ "$all_done" == "yes" ]]; then
        fetch_all_done
      else
        [[ $# -eq 1 ]] || {
          usage
          exit 1
        }

        fetch_job "$1" "$clean"
      fi
      ;;

    submit)
      local keep="no"
      local detach="no"
      local wait_seconds=0
      local array_range=""
      local exclude_list=""
      local gpu_wanted=""
      local ngpu=""

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --keep)
            keep="yes"
            shift
            ;;
          --detach)
            detach="yes"
            shift
            ;;
          --wait)
            wait_seconds="${2:?missing seconds after --wait}"
            shift 2
            ;;
          --gpu)
            gpu_wanted="${2:?missing GPU id after --gpu}"
            shift 2
            ;;
          --ngpu)
            ngpu="${2:?missing GPU count after --ngpu}"
            shift 2
            ;;
          --array)
            array_range="${2:?missing range after --array}"
            shift 2
            ;;
          --exclude)
            exclude_list="$(append_exclude "$exclude_list" "${2:?missing node name after --exclude}")"
            shift 2
            ;;
          --help|-h)
            usage
            exit 0
            ;;
          *)
            break
            ;;
        esac
      done

      [[ $# -eq 4 ]] || {
        usage
        exit 1
      }

      local node_arg="$1" input_dir="$2" run_script="$3" output_dir="$4"

      if [[ -n "$gpu_wanted" && -n "$ngpu" ]]; then
        err "--gpu and --ngpu cannot be used together"
        exit 1
      fi

      if [[ -n "$gpu_wanted" ]]; then
        gpu_wanted="$(normalize_gpu_list "$gpu_wanted")" || {
          err "--gpu expects one physical GPU index or a comma-separated list of unique physical GPU indexes"
          exit 1
        }

        [[ "$node_arg" != "--auto" ]] || {
          err "--gpu cannot be used with --auto; use --ngpu with --auto"
          exit 1
        }

        ngpu="$(csv_count "$gpu_wanted")"
      else
        ngpu="${ngpu:-1}"

        validate_ngpu "$ngpu" || {
          err "--ngpu expects a positive integer"
          exit 1
        }
      fi

      if [[ -n "$array_range" ]]; then
        submit_array \
          "$node_arg" "$input_dir" "$run_script" "$output_dir" \
          "$keep" "$wait_seconds" "$array_range" "$exclude_list" \
          "$gpu_wanted" "$ngpu"
      else
        submit_one_job \
          "$node_arg" "$input_dir" "$run_script" "$output_dir" \
          "$keep" "$detach" "$wait_seconds" "-" "-" "-" \
          "$exclude_list" "$gpu_wanted" "$ngpu"
      fi
      ;;

    help|--help|-h)
      usage
      ;;

    *)
      err "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
