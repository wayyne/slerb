#!/usr/bin/env bash
set -euo pipefail

SLERB_HOME="${SLERB_HOME:-$HOME/.slerb}"
NODES_FILE="${SLERB_NODES_FILE:-$SLERB_HOME/nodes.tsv}"
JOBS_FILE="${SLERB_JOBS_FILE:-$SLERB_HOME/jobs.tsv}"
QUEUE_FILE="${SLERB_QUEUE_FILE:-$SLERB_HOME/queue.tsv}"
QUEUE_DIR="${SLERB_QUEUE_DIR:-$SLERB_HOME/queue}"
DISPATCH_LOCK_DIR="${SLERB_DISPATCH_LOCK_DIR:-$SLERB_HOME/dispatch.lock}"
DISPATCH_INTERVAL="${SLERB_DISPATCH_INTERVAL:-30}"
DEFAULT_ENV_FILE="${SLERB_ENV_FILE:-~/.slerb_env}"

SSH_OPTS=(-o BatchMode=yes -o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new)

mkdir -p "$SLERB_HOME" "$QUEUE_DIR"
touch "$JOBS_FILE" "$QUEUE_FILE"

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  C_GREEN=$'\033[32m'
  C_RED=$'\033[31m'
  C_YELLOW=$'\033[33m'
  C_BUSY=$'\033[38;5;178m'
  C_RESERVED=$'\033[35m'
  C_DIM=$'\033[2m'
  C_RESET=$'\033[0m'
else
  C_GREEN=""
  C_RED=""
  C_YELLOW=""
  C_BUSY=""
  C_RESERVED=""
  C_DIM=""
  C_RESET=""
fi

usage() {
  cat <<USAGE
SLERB - SSH-Launched Execution Resource Broker
Like SLURM, but with more duct tape.

Usage:
  slerb status
  slerb validate [nodes.tsv]
  slerb submit [options] <node|--auto> <input_dir> <run_script> <output_dir>
  slerb jobs [n]
  slerb queue
  slerb dispatch [--interval SECONDS]
  slerb arrays
  slerb cancel <job_id>
  slerb restart [--force] <job_id>
  slerb reserve <node> [--gpu ID] [--reason TEXT]
  slerb release <node> [--gpu ID]
  slerb fetch <job_id>
  slerb fetch --clean <job_id>
  slerb fetch --all-done
  slerb log <job_id>

Submit options:
  --keep              Keep remote job directory after successful fetch
  --detach            Launch job and return immediately
  --wait SECONDS      Wait/retry if no GPU is available instead of queueing
  --gpu ID[,ID...]    Target specific physical GPU index(es) on a node
  --ngpu N            Request any N free GPUs on the selected node
  --array RANGE       Array range, for example 1-15 or 1,3,7-9
  --exclude NODES     Exclude node(s) from --auto selection, comma-separated okay

Queue behavior:
  If a job cannot launch immediately because GPUs or nodes are unavailable,
  it is queued automatically and a dispatcher is started if needed.
  Queued jobs always launch detached when resources become available.

Dispatch options:
  --interval SECONDS  Poll interval while queued jobs remain, default: 30

Reserve options:
  --gpu ID            Reserve or release one physical GPU index
  --reason TEXT       Record why a reservation exists

Examples:
  ./slerb status
  ./slerb submit jill . ./submit.sh ./slerb-results
  ./slerb submit --gpu 0,1 jill . ./submit.sh ./slerb-results
  ./slerb submit --ngpu 2 --auto . ./submit.sh ./slerb-results
  ./slerb queue
  ./slerb dispatch
  ./slerb submit --exclude atlantis --array 1-15 --wait 60 --auto . ./submit.sh ./slerb-results
  ./slerb submit --exclude atlantis,odyssey --array 1-15 --wait 60 --auto . ./submit.sh ./slerb-results
  ./slerb reserve explorer --gpu 1 --reason "local use"
  ./slerb release explorer --gpu 1
  ./slerb fetch --all-done
USAGE
}

log_msg() {
  printf '[%(%Y-%m-%d %H:%M:%S)T] %s\n' -1 "$*" >&2
}

err() {
  printf 'ERROR: %s\n' "$*" >&2
}

trim() {
  local s="$*"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

ssh_target() {
  local user="$1" host="$2"
  if [[ -n "$user" && "$user" != "-" ]]; then
    printf '%s@%s' "$user" "$host"
  else
    printf '%s' "$host"
  fi
}

remote_quote() {
  printf "%q" "$1"
}

append_exclude() {
  local current="$1"
  local add="$2"

  if [[ -z "$current" ]]; then
    printf '%s' "$add"
  else
    printf '%s,%s' "$current" "$add"
  fi
}

is_excluded_node() {
  local node="$1"
  local exclude_list="${2:-}"
  local item

  [[ -z "$exclude_list" ]] && return 1

  IFS=',' read -ra _slerb_excluded_nodes <<< "$exclude_list"

  for item in "${_slerb_excluded_nodes[@]}"; do
    item="$(trim "$item")"
    [[ -z "$item" ]] && continue

    if [[ "$node" == "$item" ]]; then
      return 0
    fi
  done

  return 1
}

ensure_nodes_file() {
  if [[ ! -f "$NODES_FILE" ]]; then
    cat > "$NODES_FILE" <<EOF_NODES
# name<TAB>user<TAB>host<TAB>env_file<TAB>tags
# jill  $USER   localhost       ~/.slerb_env    gpu
EOF_NODES
    err "Created $NODES_FILE. Edit it and add nodes."
    exit 1
  fi
}

read_nodes() {
  ensure_nodes_file

  awk '
    /^[[:space:]]*($|#)/ {next}

    NF < 4 {
      next
    }

    {
      name=$1
      user=$2
      host=$3
      env_file=$4
      tags=$5

      if (env_file == "") env_file="~/.slerb_env"
      if (tags == "") tags="-"

      printf "%s\t%s\t%s\t%s\t%s\n", name, user, host, env_file, tags
    }
  ' "$NODES_FILE"
}

get_node() {
  local wanted="$1"
  read_nodes | awk -F'\t' -v n="$wanted" '$1 == n {print; found=1; exit} END {if (!found) exit 1}'
}

kv_get() {
  local key="$1"
  awk -F'=' -v k="$key" '$1 == k {sub(k"=", ""); print; exit}'
}

mib_to_gib() {
  local mib="${1:-0}"
  awk -v m="$mib" 'BEGIN {printf "%.1f", (m+0)/1024}'
}

short_gpu_name() {
  local name="$*"

  name="${name#NVIDIA }"
  name="${name#GeForce }"

  case "$name" in
    RTX\ PRO\ 6000*) printf 'RTX PRO 6000' ;;
    RTX\ PRO\ 5000*) printf 'RTX PRO 5000' ;;
    RTX\ PRO\ 4000*) printf 'RTX PRO 4000' ;;
    RTX\ A6000*) printf 'RTX A6000' ;;
    RTX\ A5000*) printf 'RTX A5000' ;;
    RTX\ A4000*) printf 'RTX A4000' ;;
    RTX\ 6000*) printf 'RTX 6000' ;;
    RTX\ 5000*) printf 'RTX 5000' ;;
    RTX\ 4090*) printf 'RTX 4090' ;;
    RTX\ 4080*) printf 'RTX 4080' ;;
    RTX\ 3090\ Ti*) printf 'RTX 3090 Ti' ;;
    RTX\ 3090*) printf 'RTX 3090' ;;
    RTX\ 3080\ Ti*) printf 'RTX 3080 Ti' ;;
    RTX\ 3080*) printf 'RTX 3080' ;;
    RTX\ 2080\ Ti*) printf 'RTX 2080 Ti' ;;
    RTX\ 2080*) printf 'RTX 2080' ;;
    *) printf '%s' "$name" ;;
  esac
}

color_status() {
  local s="$1"

  case "$s" in
    OK|DONE|free)
      printf '%s%s%s' "$C_GREEN" "$s" "$C_RESET"
      ;;
    busy)
      printf '%s%s%s' "$C_BUSY" "$s" "$C_RESET"
      ;;
    CANCELED)
      printf '%s%s%s' "$C_YELLOW" "$s" "$C_RESET"
      ;;
    LOCKED|DOWN|FAIL|FAILED|ERROR|MISSING|LOST|KILLED)
      printf '%s%s%s' "$C_RED" "$s" "$C_RESET"
      ;;
    RUNNING|DETACHED|STAGED|WAITING)
      printf '%s%s%s' "$C_YELLOW" "$s" "$C_RESET"
      ;;
    *)
      printf '%s' "$s"
      ;;
  esac
}

remote_probe_raw() {
  local target="$1" env_file="$2"

  ssh "${SSH_OPTS[@]}" "$target" bash -s -- "$env_file" <<'REMOTE'
set -u

env_file="$1"

if [[ -f "$env_file" ]]; then
  source "$env_file" >/dev/null 2>&1 || true
fi

SLERB_SCRATCH="${SLERB_SCRATCH:-$HOME/slerb}"
SLERB_JOBS_ROOT="${SLERB_JOBS_ROOT:-$SLERB_SCRATCH/jobs}"
SLERB_LOCKS_ROOT="${SLERB_LOCKS_ROOT:-$SLERB_SCRATCH/locks}"

mkdir -p "$SLERB_JOBS_ROOT" "$SLERB_LOCKS_ROOT" >/dev/null 2>&1 || true

host="$(hostname -s 2>/dev/null || hostname)"
cores="$(nproc 2>/dev/null || echo 1)"
load1="$(awk '{print $1}' /proc/loadavg 2>/dev/null || echo 0)"
mem_total="$(awk '/MemTotal:/ {printf "%.1f", $2/1024/1024}' /proc/meminfo 2>/dev/null || echo 0)"
mem_avail="$(awk '/MemAvailable:/ {printf "%.1f", $2/1024/1024}' /proc/meminfo 2>/dev/null || echo 0)"
mem_used="$(awk -v t="$mem_total" -v a="$mem_avail" 'BEGIN {printf "%.1f", t-a}')"
scratch_free="$(df -BG "$SLERB_SCRATCH" 2>/dev/null | awk 'NR==2 {gsub("G","",$4); print $4+0}' || echo 0)"
cpu_free="$(awk -v c="$cores" -v l="$load1" 'BEGIN {f=int(c-l); if (f<0) f=0; print f}')"
gpu_lock_count="$(find "$SLERB_LOCKS_ROOT" -maxdepth 1 -type d -name 'gpu-*.lock' 2>/dev/null | wc -l | tr -d ' ')"
host_reserved="no"
host_reason="-"

if [[ -d "$SLERB_LOCKS_ROOT/host.lock" ]]; then
  host_reserved="yes"

  if [[ -f "$SLERB_LOCKS_ROOT/host.lock/info" ]]; then
    host_reason="$(awk -F= '$1=="reason" {sub($1"=", ""); print; exit}' "$SLERB_LOCKS_ROOT/host.lock/info")"
    host_reason="${host_reason:-reserved}"
  else
    host_reason="reserved"
  fi
fi

host_reason="${host_reason//$'\t'/ }"
lock_count="$gpu_lock_count"
[[ "$host_reserved" == "yes" ]] && lock_count=$((lock_count + 1))

printf 'META\thost=%s\tcores=%s\tcpu_free=%s\tload1=%s' \
  "$host" "$cores" "$cpu_free" "$load1"
printf '\tmem_used=%s\tmem_avail=%s\tmem_total=%s' \
  "$mem_used" "$mem_avail" "$mem_total"
printf '\tscratch=%s\tlocks=%s\tscratch_root=%s' \
  "$scratch_free" "$lock_count" "$SLERB_SCRATCH"
printf '\thost_reserved=%s\thost_reason=%s\n' \
  "$host_reserved" "$host_reason"

if command -v nvidia-smi >/dev/null 2>&1; then
  nvidia-smi \
    --query-gpu=index,name,utilization.gpu,memory.used,memory.total \
    --format=csv,noheader,nounits 2>/dev/null | \
    while IFS=',' read -r idx name util mem_used_gpu mem_total_gpu; do
      idx="$(echo "$idx" | xargs)"
      name="$(echo "$name" | xargs)"
      util="$(echo "$util" | xargs)"
      mem_used_gpu="$(echo "$mem_used_gpu" | xargs)"
      mem_total_gpu="$(echo "$mem_total_gpu" | xargs)"

      lock_dir="$SLERB_LOCKS_ROOT/gpu-$idx.lock"
      state="free"

      if [[ "$host_reserved" == "yes" ]]; then
        state="reserved"
      elif [[ -d "$lock_dir" ]]; then
        lock_type=""

        if [[ -f "$lock_dir/info" ]]; then
          lock_type="$(awk -F= '$1=="type" {print $2; exit}' "$lock_dir/info")"
        fi

        if [[ "$lock_type" == "reservation" ]]; then
          state="reserved"
        else
          state="locked"
        fi
      elif [[ "${util:-0}" -gt 5 || "${mem_used_gpu:-0}" -gt 512 ]]; then
        state="busy"
      fi

      printf 'GPU\tidx=%s\tstate=%s\tutil=%s\tmem_used=%s' \
        "$idx" "$state" "$util" "$mem_used_gpu"
      printf '\tmem_total=%s\tname=%s\n' "$mem_total_gpu" "$name"
    done
else
  printf 'NOGPU\n'
fi
REMOTE
}

status_all() {
  ensure_nodes_file

  local sep c_node
  sep="--------------------------------------------------------------------------------"
  c_node=""
  if [[ -n "${C_RESET:-}" ]]; then
    c_node=$'\033[38;5;109m'
  fi

  printf '%-13s %-8s %-7s %-6s %-13s %-9s %-18s\n' \
    "NODE" "STATUS" "CPU" "LOAD" "MEM" "SCRATCH" "TAGS"
  printf '%s%s%s\n' "$C_DIM" "$sep" "$C_RESET"

  while IFS=$'\t' read -r name user host env_file tags; do
    [[ -z "${name:-}" ]] && continue

    env_file="${env_file:-$DEFAULT_ENV_FILE}"
    tags="${tags:--}"

    local target out rc
    target="$(ssh_target "$user" "$host")"

    set +e
    out="$(remote_probe_raw "$target" "$env_file" 2>&1)"
    rc=$?
    set -e

    if [[ $rc -ne 0 ]]; then
      printf '%s%-13.13s%s %s%-8.8s %-7.7s %-6.6s ' \
        "$c_node" "$name" "$C_RESET" "$C_DIM" \
        "DOWN" "-" "-"
      printf '%-13.13s %-9.9s %-18.18s%s\n' \
        "-" "-" "$tags" "$C_RESET"
      printf '  %s\n' "$out" | head -n 3
      printf '%s%s%s\n' "$C_DIM" "$sep" "$C_RESET"
      continue
    fi

    local meta cores cpu_free load1 mem_used mem_avail mem_total
    local scratch locks scratch_root host_reserved host_reason
    meta="$(printf '%s\n' "$out" | awk -F'\t' '
      $1=="META" {for (i=2;i<=NF;i++) print $i}
    ')"
    cores="$(printf '%s\n' "$meta" | kv_get cores)"
    cpu_free="$(printf '%s\n' "$meta" | kv_get cpu_free)"
    load1="$(printf '%s\n' "$meta" | kv_get load1)"
    mem_used="$(printf '%s\n' "$meta" | kv_get mem_used)"
    mem_avail="$(printf '%s\n' "$meta" | kv_get mem_avail)"
    mem_total="$(printf '%s\n' "$meta" | kv_get mem_total)"
    scratch="$(printf '%s\n' "$meta" | kv_get scratch)"
    locks="$(printf '%s\n' "$meta" | kv_get locks)"
    scratch_root="$(printf '%s\n' "$meta" | kv_get scratch_root)"
    host_reserved="$(printf '%s\n' "$meta" | kv_get host_reserved)"
    host_reason="$(printf '%s\n' "$meta" | kv_get host_reason)"

    local cpu_used cpu_display gpu_count free_gpu_count
    local node_status mem_display scratch_display detail

    if [[ "$cores" =~ ^[0-9]+$ && "$cpu_free" =~ ^[0-9]+$ ]]; then
      cpu_used=$((cores - cpu_free))
      (( cpu_used < 0 )) && cpu_used=0
      cpu_display="${cpu_used}/${cores}"
    else
      cpu_display="-"
    fi

    gpu_count="$(printf '%s\n' "$out" | awk -F'\t' '
      $1=="GPU" {n++} END {print n+0}
    ')"
    free_gpu_count="$(printf '%s\n' "$out" | awk -F'\t' '
      $1=="GPU" {
        for (i=2; i<=NF; i++) {
          if ($i == "state=free") n++
        }
      }
      END {print n+0}
    ')"

    if [[ "$host_reserved" == "yes" ]]; then
      node_status="RESERVED"
    elif [[ "$gpu_count" -eq 0 ]]; then
      node_status="NOGPU"
    elif [[ "$free_gpu_count" -gt 0 ]]; then
      node_status="READY"
    else
      node_status="BUSY"
    fi

    mem_display="${mem_used}/${mem_total}G"
    scratch_display="${scratch}G"

    printf '%s%-13.13s%s %s%-8.8s %-7.7s %-6.6s ' \
      "$c_node" "$name" "$C_RESET" "$C_DIM" \
      "$node_status" "$cpu_display" "$load1"
    printf '%-13.13s %-9.9s %-18.18s%s\n' \
      "$mem_display" "$scratch_display" "$tags" "$C_RESET"

    if [[ "$host_reserved" == "yes" ]]; then
      printf -v detail '  reserve=host reason=%s scratch=%s locks=%s' \
        "${host_reason:--}" "$scratch_root" "$locks"
    else
      printf -v detail '  scratch=%s  locks=%s' "$scratch_root" "$locks"
    fi
    printf '%s%.80s%s\n' "$C_DIM" "$detail" "$C_RESET"

    if [[ "$gpu_count" -gt 0 ]]; then
      while IFS=$'\t' read -r rec f1 f2 f3 f4 f5 f6; do
        [[ "$rec" == "GPU" ]] || continue

        local idx="" state="" util="" mem_used_gpu=""
        local mem_total_gpu="" gpu_name=""
        local field key value state_l mem_used_gib mem_total_gib
        local short_name state_color

        for field in "$f1" "$f2" "$f3" "$f4" "$f5" "$f6"; do
          [[ -z "$field" ]] && continue

          key="${field%%=*}"
          value="${field#*=}"

          case "$key" in
            idx) idx="$value" ;;
            state) state="$value" ;;
            util) util="$value" ;;
            mem_used) mem_used_gpu="$value" ;;
            mem_total) mem_total_gpu="$value" ;;
            name) gpu_name="$value" ;;
          esac
        done

        state_l="${state,,}"
        mem_used_gib="$(mib_to_gib "$mem_used_gpu")"
        mem_total_gib="$(mib_to_gib "$mem_total_gpu")"
        short_name="$(short_gpu_name "$gpu_name")"

        case "$state_l" in
          free) state_color="$C_GREEN" ;;
          busy) state_color="$C_BUSY" ;;
          reserved) state_color="$C_RESERVED" ;;
          locked) state_color="$C_RED" ;;
          *) state_color="" ;;
        esac

        printf '  GPU%-2s %s%-8s%s util=%-5s ' \
          "$idx" "$state_color" "$state_l" "$C_RESET" "${util}%"
        printf 'mem=%s/%sG  %.22s\n' \
          "$mem_used_gib" "$mem_total_gib" "$short_name"
      done < <(printf '%s\n' "$out")
    else
      printf '  GPU       none\n'
    fi

    printf '%s%s%s\n' "$C_DIM" "$sep" "$C_RESET"
  done < <(read_nodes)
}

validate_nodes() {
  local file="${1:-$NODES_FILE}"

  if [[ ! -f "$file" ]]; then
    err "No such nodes file: $file"
    exit 1
  fi

  awk '
    /^[[:space:]]*($|#)/ {next}

    NF < 4 {
      printf "BAD line %d: expected at least 4 whitespace-separated fields\n", NR
      bad=1
      next
    }

    {
      printf "OK  line %d: %s -> %s@%s env=%s tags=%s\n", NR, $1, $2, $3, $4, (NF>=5?$5:"-")
    }

    END {exit bad}
  ' "$file"
}

choose_auto_node() {
  local exclude_list="${1:-}"
  local gpu_count_needed="${2:-1}"
  ensure_nodes_file

  [[ "$gpu_count_needed" =~ ^[0-9]+$ && "$gpu_count_needed" -ge 1 ]] || {
    err "Internal error: invalid GPU count requested: $gpu_count_needed"
    return 1
  }

  local best="" best_score=-999999

  while IFS=$'\t' read -r name user host env_file tags; do
    [[ -z "${name:-}" ]] && continue

    if is_excluded_node "$name" "$exclude_list"; then
      continue
    fi

    env_file="${env_file:-$DEFAULT_ENV_FILE}"

    local target out rc
    target="$(ssh_target "$user" "$host")"

    set +e
    out="$(remote_probe_raw "$target" "$env_file" 2>/dev/null)"
    rc=$?
    set -e

    [[ $rc -ne 0 ]] && continue

    local free_gpus scratch cpu_free meta score
    free_gpus="$(printf '%s\n' "$out" | awk -F'\t' '$1=="GPU" && $0 ~ /state=free/ {n++} END{print n+0}')"
    [[ "$free_gpus" -lt "$gpu_count_needed" ]] && continue

    meta="$(printf '%s\n' "$out" | awk -F'\t' '$1=="META" {for (i=2;i<=NF;i++) print $i}')"
    scratch="$(printf '%s\n' "$meta" | kv_get scratch)"
    cpu_free="$(printf '%s\n' "$meta" | kv_get cpu_free)"

    score=$(( free_gpus * 100000 + cpu_free * 100 + scratch ))

    if [[ "$score" -gt "$best_score" ]]; then
      best_score="$score"
      best="$name"
    fi
  done < <(read_nodes)

  [[ -n "$best" ]] && printf '%s' "$best"
}

expand_array_range() {
  local spec="$1"
  local IFS=',' part start end step i

  for part in $spec; do
    if [[ "$part" =~ ^([0-9]+)-([0-9]+):([0-9]+)$ ]]; then
      start="${BASH_REMATCH[1]}"
      end="${BASH_REMATCH[2]}"
      step="${BASH_REMATCH[3]}"
    elif [[ "$part" =~ ^([0-9]+)-([0-9]+)$ ]]; then
      start="${BASH_REMATCH[1]}"
      end="${BASH_REMATCH[2]}"
      step=1
    elif [[ "$part" =~ ^[0-9]+$ ]]; then
      printf '%s\n' "$part"
      continue
    else
      err "Bad array range component: $part"
      exit 1
    fi

    if (( start <= end )); then
      for ((i=start; i<=end; i+=step)); do
        printf '%s\n' "$i"
      done
    else
      for ((i=start; i>=end; i-=step)); do
        printf '%s\n' "$i"
      done
    fi
  done
}

normalize_gpu_list() {
  local raw="$1"
  local item out="" seen=","

  [[ -n "$raw" ]] || return 1

  IFS=',' read -ra _slerb_gpu_list_parts <<< "$raw"

  for item in "${_slerb_gpu_list_parts[@]}"; do
    item="$(trim "$item")"

    [[ "$item" =~ ^[0-9]+$ ]] || return 1

    case "$seen" in
      *,"$item",*) return 1 ;;
    esac

    seen="${seen}${item},"

    if [[ -z "$out" ]]; then
      out="$item"
    else
      out="${out},${item}"
    fi
  done

  [[ -n "$out" ]] || return 1
  printf '%s' "$out"
}

csv_count() {
  local csv="$1"

  [[ -n "$csv" ]] || {
    printf '0'
    return 0
  }

  awk -F',' '{print NF}' <<< "$csv"
}

validate_ngpu() {
  local n="$1"

  [[ "$n" =~ ^[0-9]+$ && "$n" -ge 1 ]]
}

history_append() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$@" >> "$JOBS_FILE"
}

history_update() {
  local job_id="$1" status="$2" exit_code="$3" end_time="$4"
  local tmp
  tmp="$(mktemp)"

  awk -F'\t' -v OFS='\t' -v id="$job_id" -v st="$status" -v ec="$exit_code" -v et="$end_time" '
    $1 == id {$2=st; $3=ec; $7=et}
    {print}
  ' "$JOBS_FILE" > "$tmp"

  mv "$tmp" "$JOBS_FILE"
}


history_record_launch() {
  local job_id="$1" status="$2" exit_code="$3" node="$4"
  local target="$5" start_time="$6" end_time="$7" local_dir="$8"
  local remote_dir="$9" keep="${10}" input_dir="${11}" run_script="${12}"
  local gpu_id="${13}" array_range="${14}" array_task="${15}" array_id="${16}"
  local tmp found_file

  tmp="$(mktemp)"
  found_file="$(mktemp)"

  awk -F'\t' -v OFS='\t' \
    -v id="$job_id" -v st="$status" -v ec="$exit_code" \
    -v node="$node" -v target="$target" -v start="$start_time" \
    -v end="$end_time" -v local_dir="$local_dir" \
    -v remote_dir="$remote_dir" -v keep="$keep" \
    -v input_dir="$input_dir" -v run_script="$run_script" \
    -v gpu_id="$gpu_id" -v array_range="$array_range" \
    -v array_task="$array_task" -v array_id="$array_id" \
    -v found_file="$found_file" '
    $1 == id {
      $2=st
      $3=ec
      $4=node
      $5=target
      $6=start
      $7=end
      $8=local_dir
      $9=remote_dir
      $10=keep
      $11=input_dir
      $12=run_script
      $13=gpu_id
      $14=array_range
      $15=array_task
      $16=array_id
      found=1
    }
    {print}
    END {if (found) print "found" > found_file}
  ' "$JOBS_FILE" > "$tmp"

  if [[ -s "$found_file" ]]; then
    mv "$tmp" "$JOBS_FILE"
  else
    rm -f "$tmp"
    history_append "$job_id" "$status" "$exit_code" "$node" "$target" \
      "$start_time" "$end_time" "$local_dir" "$remote_dir" "$keep" \
      "$input_dir" "$run_script" "$gpu_id" "$array_range" \
      "$array_task" "$array_id"
  fi

  rm -f "$found_file"
}

history_restart_update() {
