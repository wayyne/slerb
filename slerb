reason="${reason//$'\t'/ }"
reason="${reason//$'\n'/ }"
actor="${USER:-unknown}"
host="$(hostname -s 2>/dev/null || hostname)"
created="$(date -Is)"

write_info() {
  local lock_dir="$1" lock_scope="$2" gpu_id="${3:-}" gpu_uuid="${4:-}"

  {
    printf 'type=reservation\n'
    printf 'scope=%s\n' "$lock_scope"
    [[ -n "$gpu_id" ]] && printf 'gpu_id=%s\n' "$gpu_id"
    [[ -n "$gpu_uuid" ]] && printf 'gpu_uuid=%s\n' "$gpu_uuid"
    printf 'user=%s\n' "$actor"
    printf 'host=%s\n' "$host"
    printf 'created=%s\n' "$created"
    printf 'reason=%s\n' "$reason"
  } > "$lock_dir/info"
}

case "$scope" in
  host)
    lock_dir="$SLERB_LOCKS_ROOT/host.lock"

    if ! mkdir "$lock_dir" 2>/dev/null; then
      echo "RESERVE_EXISTS=host"
      exit 65
    fi

    write_info "$lock_dir" "host"
    echo "RESERVED_HOST"
    exit 0
    ;;

  gpu)
    [[ -n "$gpu_wanted" ]] || {
      echo "MISSING_GPU"
      exit 64
    }
    ;;

  *)
    echo "BAD_SCOPE=$scope"
    exit 64
    ;;
esac

if ! command -v nvidia-smi >/dev/null 2>&1; then
  echo "NO_NVIDIA_GPU"
  exit 60
fi

gpu_uuid="$(
  nvidia-smi --query-gpu=index,uuid --format=csv,noheader,nounits | \
    awk -F',' -v wanted="$gpu_wanted" '
      {
        idx=$1
        uuid=$2
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", idx)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", uuid)
        if (idx == wanted) {print uuid; exit}
      }
    '
)"

if [[ -z "$gpu_uuid" ]]; then
  echo "NO_SUCH_GPU=$gpu_wanted"
  exit 66
fi

lock_dir="$SLERB_LOCKS_ROOT/gpu-$gpu_wanted.lock"

if ! mkdir "$lock_dir" 2>/dev/null; then
  echo "RESERVE_EXISTS=gpu-$gpu_wanted"
  exit 65
fi

write_info "$lock_dir" "gpu" "$gpu_wanted" "$gpu_uuid"
echo "RESERVED_GPU=$gpu_wanted"
