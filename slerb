show_jobs() {
  local n="${1:-30}"

  printf '%-32s %-10s %-5s %-12s %-5s %-8s %-19s %s\n' "JOB_ID" "STATUS" "EXIT" "NODE" "GPU" "TASK" "START" "RESULT_DIR"

  tail -n "$n" "$JOBS_FILE" | while IFS=$'\t' read -r job_id status exit_code node target start_time end_time local_dir remote_dir keep input_dir run_script gpu_id array_range array_task array_id; do
    [[ -z "${job_id:-}" ]] && continue
    printf '%-32s %-10s %-5s %-12s %-5s %-8s %-19s %s\n' "$job_id" "$status" "$exit_code" "$node" "$gpu_id" "$array_task" "$start_time" "$local_dir"
  done
