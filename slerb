env_file="$1"
remote_dir="$2"
job_id="$3"
gpu_wanted="${4:-}"
[[ "$gpu_wanted" == "-" ]] && gpu_wanted=""
force="${5:-no}"

case "$force" in
  yes|no) ;;
  *)
    echo "BAD_FORCE=$force"
    exit 64
    ;;
esac

if [[ -f "$env_file" ]]; then
  source "$env_file"
fi

SLERB_SCRATCH="${SLERB_SCRATCH:-$HOME/slerb}"
SLERB_JOBS_ROOT="${SLERB_JOBS_ROOT:-$SLERB_SCRATCH/jobs}"
SLERB_LOCKS_ROOT="${SLERB_LOCKS_ROOT:-$SLERB_SCRATCH/locks}"
SLERB_WORK_ROOT="${SLERB_WORK_ROOT:-$SLERB_SCRATCH/work}"

export SLERB_SCRATCH SLERB_JOBS_ROOT SLERB_LOCKS_ROOT SLERB_WORK_ROOT

mkdir -p "$SLERB_JOBS_ROOT" "$SLERB_LOCKS_ROOT" "$SLERB_WORK_ROOT"

state_file="$remote_dir/.slerb_state"

if [[ -f "$state_file" ]]; then
  source "$state_file"
fi

work_dir="${WORK_DIR:-$remote_dir/work}"
gpu_ids="$gpu_wanted"

if [[ -z "$gpu_ids" || "$gpu_ids" == "-" ]]; then
  gpu_ids="${GPU_IDS:-${GPU_ID:-}}"
fi

if [[ -z "$gpu_ids" || "$gpu_ids" == "-" ]]; then
  echo "MISSING_GPU_ID"
  exit 64
fi

trim_remote() {
  local s="$*"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

append_csv() {
  local current="$1" add="$2"

  if [[ -z "$current" ]]; then
    printf '%s' "$add"
  else
    printf '%s,%s' "$current" "$add"
  fi
}

normalize_gpu_ids_remote() {
  local raw="$1" item out="" seen=","

  IFS=',' read -ra _slerb_restart_gpu_ids <<< "$raw"

  for item in "${_slerb_restart_gpu_ids[@]}"; do
    item="$(trim_remote "$item")"

    [[ "$item" =~ ^[0-9]+$ ]] || return 1

    case "$seen" in
      *,"$item",*) return 1 ;;
    esac

    seen="${seen}${item},"
    out="$(append_csv "$out" "$item")"
  done

  [[ -n "$out" ]] || return 1
  printf '%s' "$out"
}

gpu_ids="$(normalize_gpu_ids_remote "$gpu_ids")" || {
  echo "BAD_GPU_ID=$gpu_ids"
  exit 64
}

gpu_count="$(awk -F',' '{print NF}' <<< "$gpu_ids")"

lock_dirs_for_gpu_ids() {
  local ids="$1" id out=""

  IFS=',' read -ra _slerb_lock_gpu_ids <<< "$ids"

  for id in "${_slerb_lock_gpu_ids[@]}"; do
    out="$(append_csv "$out" "$SLERB_LOCKS_ROOT/gpu-$id.lock")"
  done

  printf '%s' "$out"
}

target_lock_dirs="$(lock_dirs_for_gpu_ids "$gpu_ids")"

remove_restart_lock_if_ours() {
  local candidate="$1"
  local lock_type="" lock_job_id=""

  [[ -n "$candidate" ]] || return 0
  [[ -d "$candidate" ]] || return 0

  case "$candidate" in
    "$SLERB_LOCKS_ROOT"/gpu-*.lock) ;;
    *) return 0 ;;
  esac

  if [[ -f "$candidate/info" ]]; then
    lock_type="$(awk -F= '$1=="type" {print $2; exit}' "$candidate/info")"
    lock_job_id="$(awk -F= '$1=="job_id" {print $2; exit}' "$candidate/info")"
  fi

  if [[ "$lock_type" == "reservation" ]]; then
    echo "GPU_RESERVED=${candidate##*/}"
    exit 65
  fi

  if [[ "$lock_job_id" == "$job_id" ]]; then
    rm -rf "$candidate"
    return 0
  fi

  if [[ -z "$lock_job_id" && "$force" == "yes" ]]; then
    rm -rf "$candidate"
    return 0
  fi

  if [[ -z "$lock_job_id" ]]; then
    echo "GPU_LOCK_EXISTS_WITHOUT_JOB_ID=${candidate##*/}"
    exit 65
  fi

  echo "GPU_LOCKED_BY_OTHER_JOB=$lock_job_id"
  exit 65
}

remove_lock_csv_if_ours() {
  local dirs="$1" dir

  IFS=',' read -ra _slerb_restart_lock_dirs <<< "$dirs"

  for dir in "${_slerb_restart_lock_dirs[@]}"; do
    remove_restart_lock_if_ours "$dir"
  done
}

if [[ ! -d "$remote_dir" ]]; then
  remove_lock_csv_if_ours "$target_lock_dirs"
  echo "MISSING_REMOTE_DIR=$remote_dir"
  exit 76
fi

if [[ ! -f "$work_dir/run.sh" ]]; then
  remove_lock_csv_if_ours "${LOCK_DIRS:-${LOCK_DIR:-}}"
  remove_lock_csv_if_ours "$target_lock_dirs"
  echo "MISSING_RUN_SCRIPT=$work_dir/run.sh"
  exit 78
fi

job_pids() {
  local self self_pgid pid cwd

  self="$$"
  self_pgid="$(ps -o pgid= -p "$self" 2>/dev/null | tr -d ' ')"

  ps -eo pid=,ppid=,pgid=,sid=,cmd= | awk \
    -v rd="$remote_dir" \
    -v wd="$work_dir" \
    -v self="$self" \
    -v self_pgid="$self_pgid" '
      {
        pid=$1
        ppid=$2
        pgid=$3
        cmd=$0
      }

      pid == self {next}
      ppid == self {next}
      pgid == self_pgid {next}

      cmd ~ /bash -s --/ {next}
      cmd ~ /awk -v rd=/ {next}
      cmd ~ /ps -eo/ {next}

      index(cmd, rd) || index(cmd, wd) {
        print pid
      }
    ' 2>/dev/null || true

  if [[ -d /proc ]]; then
    for proc_dir in /proc/[0-9]*; do
      [[ -d "$proc_dir" ]] || continue
      pid="${proc_dir##*/}"
      [[ "$pid" == "$self" ]] && continue

      cwd="$(readlink "$proc_dir/cwd" 2>/dev/null || true)"

      case "$cwd" in
        "$work_dir"|"$work_dir"/*)
          printf '%s\n' "$pid"
          ;;
      esac
    done
  fi
}

running_pids="$(job_pids | sort -n -u | tr '\n' ' ' | xargs || true)"

if [[ -n "$running_pids" && "$force" != "yes" ]]; then
  echo "JOB_STILL_RUNNING=$running_pids"
  exit 75
fi

if [[ -n "$running_pids" && "$force" == "yes" ]]; then
  # shellcheck disable=SC2086
  kill -TERM $running_pids 2>/dev/null || true

  for _ in 1 2 3 4 5; do
    sleep 1
    running_pids="$(job_pids | sort -n -u | tr '\n' ' ' | xargs || true)"
    [[ -z "$running_pids" ]] && break
  done

  if [[ -n "$running_pids" ]]; then
    # shellcheck disable=SC2086
    kill -KILL $running_pids 2>/dev/null || true
    sleep 1
  fi

  running_pids="$(job_pids | sort -n -u | tr '\n' ' ' | xargs || true)"

  if [[ -n "$running_pids" ]]; then
    echo "FAILED_TO_KILL=$running_pids"
    exit 70
  fi
fi

remove_lock_csv_if_ours "${LOCK_DIRS:-${LOCK_DIR:-}}"
remove_lock_csv_if_ours "$target_lock_dirs"

if ! command -v nvidia-smi >/dev/null 2>&1; then
  echo "NO_NVIDIA_GPU"
  exit 60
fi

cleanup_acquired_locks() {
  local dir

  IFS=',' read -ra _slerb_acquired_lock_dirs <<< "${new_lock_dirs:-}"

  for dir in "${_slerb_acquired_lock_dirs[@]}"; do
    [[ -n "$dir" ]] && rm -rf "$dir"
  done
}

find_gpu_line() {
  local wanted="$1"

  nvidia-smi \
    --query-gpu=index,uuid,utilization.gpu,memory.used \
    --format=csv,noheader,nounits | \
    awk -F',' -v wanted="$wanted" '
      {
        idx=$1
        uuid=$2
        util=$3
        mem=$4

        gsub(/^[[:space:]]+|[[:space:]]+$/, "", idx)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", uuid)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", util)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", mem)

        if (idx == wanted && found == 0) {
          printf "%s\t%s\t%s\n", uuid, util, mem
          found=1
        }
      }
    '
}

write_lock_info() {
  local lock_dir="$1" idx="$2" uuid="$3"

  {
    printf 'type=job\n'
    printf 'job_id=%s\n' "$job_id"
    printf 'user=%s\n' "$USER"
    printf 'host=%s\n' "$(hostname -s 2>/dev/null || hostname)"
    printf 'start_time=%s\n' "$(date -Is)"
    printf 'gpu_id=%s\n' "$idx"
    printf 'gpu_uuid=%s\n' "$uuid"
  } > "$lock_dir/info"
}

new_gpu_uuids=""
new_lock_dirs=""

IFS=',' read -ra restart_gpu_ids <<< "$gpu_ids"

for gpu_id in "${restart_gpu_ids[@]}"; do
  gpu_line="$(find_gpu_line "$gpu_id")"

  if [[ -z "$gpu_line" ]]; then
    cleanup_acquired_locks
    echo "NO_SUCH_GPU=$gpu_id"
    exit 66
  fi

  IFS=$'\t' read -r gpu_uuid gpu_util gpu_mem_used <<< "$gpu_line"

  [[ "$gpu_util" =~ ^[0-9]+$ ]] || gpu_util=999
  [[ "$gpu_mem_used" =~ ^[0-9]+$ ]] || gpu_mem_used=999999

  if [[ "$gpu_util" -gt 5 || "$gpu_mem_used" -gt 512 ]]; then
    cleanup_acquired_locks
    echo "GPU_BUSY=$gpu_id util=$gpu_util mem_used=$gpu_mem_used"
    exit 63
  fi

  lock_dir="$SLERB_LOCKS_ROOT/gpu-$gpu_id.lock"

  if ! mkdir "$lock_dir" 2>/dev/null; then
    cleanup_acquired_locks
    echo "GPU_LOCK_RACE=$gpu_id"
    exit 63
  fi

  write_lock_info "$lock_dir" "$gpu_id" "$gpu_uuid"
  new_gpu_uuids="$(append_csv "$new_gpu_uuids" "$gpu_uuid")"
  new_lock_dirs="$(append_csv "$new_lock_dirs" "$lock_dir")"
done

first_gpu_id="${gpu_ids%%,*}"
first_gpu_uuid="${new_gpu_uuids%%,*}"
first_lock_dir="${new_lock_dirs%%,*}"

stamp="$(date +%Y%m%d-%H%M%S)"

if [[ -f "$remote_dir/job.log" ]]; then
  mv "$remote_dir/job.log" "$remote_dir/job.log.restart-$stamp"
fi

if [[ -f "$remote_dir/exit_code" ]]; then
  mv "$remote_dir/exit_code" "$remote_dir/exit_code.restart-$stamp"
fi

rm -f "$remote_dir/pid"

{
  printf 'JOB_ID=%s\n' "$job_id"
  printf 'REMOTE_DIR=%s\n' "$remote_dir"
  printf 'WORK_DIR=%s\n' "$work_dir"
  printf 'LOCK_DIR=%s\n' "$first_lock_dir"
  printf 'LOCK_DIRS=%s\n' "$new_lock_dirs"
  printf 'GPU_ID=%s\n' "$first_gpu_id"
  printf 'GPU_IDS=%s\n' "$gpu_ids"
  printf 'GPU_UUID=%s\n' "$first_gpu_uuid"
  printf 'GPU_UUIDS=%s\n' "$new_gpu_uuids"
  printf 'GPU_COUNT=%s\n' "$gpu_count"
  printf 'SLERB_SCRATCH=%s\n' "$SLERB_SCRATCH"
  printf 'STATUS=STAGED\n'
} > "$state_file"

printf 'REMOTE_DIR=%s\n' "$remote_dir"
printf 'WORK_DIR=%s\n' "$work_dir"
printf 'GPU_ID=%s\n' "$first_gpu_id"
printf 'GPU_IDS=%s\n' "$gpu_ids"
printf 'GPU_UUID=%s\n' "$first_gpu_uuid"
printf 'GPU_UUIDS=%s\n' "$new_gpu_uuids"
printf 'GPU_COUNT=%s\n' "$gpu_count"
printf 'LOCK_DIR=%s\n' "$first_lock_dir"
printf 'LOCK_DIRS=%s\n' "$new_lock_dirs"
REMOTE
}

rsync_to_remote() {
  local src="$1" target="$2" dst="$3"

  rsync -azcL \
    --exclude '.git/' \
    --exclude '.slerb/' \
    --exclude 'slerb-results/' \
    "$src" "$target:$dst"
}

rsync_from_remote() {
  local target="$1" src="$2" dst="$3"

  mkdir -p "$dst"
  rsync -azcL "$target:$src/" "$dst/"
}

rsync_to_queue_spool() {
  local src="$1" dst="$2"

  mkdir -p "$dst"
  rsync -azcL \
    --exclude '.git/' \
    --exclude '.slerb/' \
    --exclude 'slerb-results/' \
    "$src" "$dst"
}

write_request_var() {
  local key="$1" value="${2:-}"
  printf '%s=%q\n' "$key" "$value"
}

queue_remove_job() {
  local job_id="$1"
  local tmp
  tmp="$(mktemp)"

  awk -F'\t' -v OFS='\t' -v id="$job_id" '$1 != id {print}' \
    "$QUEUE_FILE" > "$tmp"
  mv "$tmp" "$QUEUE_FILE"
}

queue_spool_dir() {
  local job_id="$1"
  awk -F'\t' -v id="$job_id" '$1 == id {print $3; exit}' "$QUEUE_FILE"
}

queue_has_jobs() {
  [[ -s "$QUEUE_FILE" ]]
}

show_queue() {
  printf '%-32s %-19s %-12s %-6s %-8s %s\n' \
    "JOB_ID" "QUEUED" "NODE" "NGPU" "GPU" "OUTPUT_DIR"

  while IFS=$'\t' read -r job_id queued_at spool_dir; do
    [[ -n "${job_id:-}" ]] || continue
    [[ -f "$spool_dir/request.env" ]] || continue

    unset NODE_ARG OUTPUT_DIR GPU_WANTED GPU_COUNT
    # shellcheck disable=SC1090
    source "$spool_dir/request.env" >/dev/null 2>&1 || true

    printf '%-32s %-19s %-12s %-6s %-8s %s\n' \
      "$job_id" "$queued_at" "${NODE_ARG:--}" "${GPU_COUNT:--}" \
      "${GPU_WANTED:--}" "${OUTPUT_DIR:--}"
  done < "$QUEUE_FILE"
}

is_resource_rc() {
  case "$1" in
    61|63|64|81)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

queue_job() {
  local job_id="$1" node_arg="$2" input_dir="$3" run_script="$4"
  local output_dir="$5" keep="$6" detach="$7" array_task="$8"
  local array_range="$9" array_id="${10}" exclude_list="${11:-}"
  local gpu_wanted="${12:-}" gpu_count="${13:-1}"
  local spool_dir spool_input queued_at local_job_dir gpu_req

  spool_dir="$QUEUE_DIR/$job_id"
  spool_input="$spool_dir/input"
  queued_at="$(date '+%Y-%m-%d %H:%M:%S')"
  local_job_dir="$output_dir/$job_id"

  rm -rf "$spool_dir"
  mkdir -p "$spool_input" "$local_job_dir"

  set +e
  rsync_to_queue_spool "$input_dir/" "$spool_input/"
  local rc=$?
  if [[ $rc -eq 0 ]]; then
    cp -L "$run_script" "$spool_dir/run.sh"
    rc=$?
  fi
  set -e

  if [[ $rc -ne 0 ]]; then
    rm -rf "$spool_dir"
    err "Could not queue $job_id: failed to snapshot input or run script"
    return "$rc"
  fi

  chmod +x "$spool_dir/run.sh" 2>/dev/null || true

  {
    write_request_var JOB_ID "$job_id"
    write_request_var NODE_ARG "$node_arg"
    write_request_var INPUT_DIR "$spool_input"
    write_request_var RUN_SCRIPT "$spool_dir/run.sh"
    write_request_var OUTPUT_DIR "$output_dir"
    write_request_var KEEP "$keep"
    write_request_var DETACH "yes"
    write_request_var ARRAY_TASK "$array_task"
    write_request_var ARRAY_RANGE "$array_range"
    write_request_var ARRAY_ID "$array_id"
    write_request_var EXCLUDE_LIST "$exclude_list"
    write_request_var GPU_WANTED "$gpu_wanted"
    write_request_var GPU_COUNT "$gpu_count"
    write_request_var ORIGINAL_INPUT_DIR "$input_dir"
    write_request_var ORIGINAL_RUN_SCRIPT "$run_script"
  } > "$spool_dir/request.env"

  gpu_req="${gpu_wanted:-ngpu:$gpu_count}"

  history_record_launch "$job_id" "QUEUED" "-" "$node_arg" "-" \
    "$queued_at" "-" "$local_job_dir" "-" "$keep" \
    "$input_dir" "$run_script" "$gpu_req" "$array_range" \
    "$array_task" "$array_id"

  queue_remove_job "$job_id"
  printf '%s\t%s\t%s\n' "$job_id" "$queued_at" "$spool_dir" >> "$QUEUE_FILE"

  log_msg "Queued $job_id; dispatcher will launch it when resources are available"
  start_dispatcher_background
  printf '%s\n' "$job_id"
}

acquire_dispatch_lock() {
  if mkdir "$DISPATCH_LOCK_DIR" 2>/dev/null; then
    printf '%s\n' "$$" > "$DISPATCH_LOCK_DIR/pid"
    return 0
  fi

  local old_pid=""
  if [[ -f "$DISPATCH_LOCK_DIR/pid" ]]; then
    old_pid="$(cat "$DISPATCH_LOCK_DIR/pid" 2>/dev/null | tr -dc '0-9')"
  fi

  if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
    return 1
  fi

  rm -rf "$DISPATCH_LOCK_DIR"

  if mkdir "$DISPATCH_LOCK_DIR" 2>/dev/null; then
    printf '%s\n' "$$" > "$DISPATCH_LOCK_DIR/pid"
    return 0
  fi

  return 1
}

release_dispatch_lock() {
  local pid=""
  if [[ -f "$DISPATCH_LOCK_DIR/pid" ]]; then
    pid="$(cat "$DISPATCH_LOCK_DIR/pid" 2>/dev/null | tr -dc '0-9')"
  fi

  if [[ "$pid" == "$$" ]]; then
    rm -rf "$DISPATCH_LOCK_DIR"
  fi
}

start_dispatcher_background() {
  if [[ "${SLERB_IN_DISPATCH:-no}" == "yes" ]]; then
    return 0
  fi

  local self="${BASH_SOURCE[0]:-$0}"
  local log_file="$SLERB_HOME/dispatch.log"

  mkdir -p "$SLERB_HOME"

  if [[ "$self" != */* ]]; then
    self="$(command -v "$self" 2>/dev/null || true)"
  fi

  if [[ -n "$self" && "$self" == */* ]]; then
    local self_dir self_base
    self_dir="$(cd "$(dirname "$self")" 2>/dev/null && pwd || true)"
    self_base="$(basename "$self")"

    if [[ -n "$self_dir" ]]; then
      self="$self_dir/$self_base"
    fi
  fi

  if [[ -z "$self" || ! -f "$self" ]]; then
    {
      printf '[%(%Y-%m-%d %H:%M:%S)T] Could not auto-start dispatcher: unable to resolve slerb path from %s\n' \
        -1 "${BASH_SOURCE[0]:-$0}"
    } >> "$log_file"
    return 0
  fi

  if [[ -f "$DISPATCH_LOCK_DIR/pid" ]]; then
    local old_pid=""
    old_pid="$(cat "$DISPATCH_LOCK_DIR/pid" 2>/dev/null | tr -dc '0-9')"

    if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
      return 0
    fi
  fi

  {
    printf '[%(%Y-%m-%d %H:%M:%S)T] Auto-starting dispatcher: %s dispatch --interval %s\n' \
      -1 "$self" "$DISPATCH_INTERVAL"
  } >> "$log_file"

  nohup "$self" dispatch --interval "$DISPATCH_INTERVAL" >> "$log_file" 2>&1 &
}

dispatch_one_queued_job() {
  local job_id="$1" spool_dir="$2"
  local request_file="$spool_dir/request.env"

  if [[ ! -f "$request_file" ]]; then
    queue_remove_job "$job_id"
    err "Queued job $job_id is missing request.env"
    return 72
  fi

  unset JOB_ID NODE_ARG INPUT_DIR RUN_SCRIPT OUTPUT_DIR KEEP DETACH
  unset ARRAY_TASK ARRAY_RANGE ARRAY_ID EXCLUDE_LIST GPU_WANTED GPU_COUNT

  # shellcheck disable=SC1090
  source "$request_file"

  if [[ "${JOB_ID:-}" != "$job_id" ]]; then
    err "Queued job $job_id has mismatched request.env"
    return 72
  fi

  history_update "$job_id" "DISPATCHING" "-" "-"

  set +e
  SLERB_IN_DISPATCH=yes submit_one_job \
    "$NODE_ARG" "$INPUT_DIR" "$RUN_SCRIPT" "$OUTPUT_DIR" \
    "$KEEP" "yes" "0" "${ARRAY_TASK:--}" "${ARRAY_RANGE:--}" \
    "${ARRAY_ID:--}" "${EXCLUDE_LIST:-}" "${GPU_WANTED:-}" \
    "${GPU_COUNT:-1}" "no" "$job_id"
  local rc=$?

  if [[ $rc -eq 0 ]]; then
    set -e
    queue_remove_job "$job_id"
    rm -rf "$spool_dir"
    return 0
  fi

  if is_resource_rc "$rc"; then
    history_update "$job_id" "QUEUED" "-" "-"
    set +e
    return "$rc"
  fi

  set -e
  queue_remove_job "$job_id"
  history_update "$job_id" "FAILED" "$rc" "$(date '+%Y-%m-%d %H:%M:%S')"
  return "$rc"
}

dispatch_queue() {
  local interval="${1:-$DISPATCH_INTERVAL}"

  [[ "$interval" =~ ^[0-9]+$ && "$interval" -ge 1 ]] || {
    err "dispatch interval must be a positive integer"
    return 1
  }

  if ! acquire_dispatch_lock; then
    log_msg "Dispatcher already running"
    return 0
  fi

  trap release_dispatch_lock EXIT INT TERM

  log_msg "Dispatcher started"

  while [[ -s "$QUEUE_FILE" ]]; do
    local job_id="" queued_at="" spool_dir="" status="" rc=0

    IFS=$'\t' read -r job_id queued_at spool_dir < "$QUEUE_FILE" || break

    if [[ -z "${job_id:-}" ]]; then
      log_msg "Queue head is empty or invalid; stopping dispatcher"
      break
    fi

    status="$(history_field "$job_id" 2)"

    if [[ "$status" != "QUEUED" && "$status" != "DISPATCHING" ]]; then
      queue_remove_job "$job_id"
      continue
    fi

    set +e
    dispatch_one_queued_job "$job_id" "$spool_dir"
    rc=$?
    set -e

    if [[ $rc -eq 0 ]]; then
      continue
    fi

    if is_resource_rc "$rc"; then
      history_update "$job_id" "QUEUED" "-" "-"
      log_msg "Queue head $job_id is not launchable yet; sleeping ${interval}s"
      sleep "$interval"
      continue
    fi

    err "Queued job $job_id failed during dispatch with exit $rc"
  done

  log_msg "Dispatcher exiting; queue is empty or inactive"

  release_dispatch_lock
  trap - EXIT INT TERM
}

submit_one_job() {
  local node_arg="$1"
  local input_dir="$2"
  local run_script="$3"
  local output_dir="$4"
  local keep="$5"
  local detach="$6"
  local wait_seconds="$7"
  local array_task="$8"
  local array_range="$9"
  local array_id="${10}"
  local exclude_list="${11:-}"
  local gpu_wanted="${12:-}"
  local gpu_count="${13:-1}"
  local queue_on_resource="${14:-yes}"
  local job_id_override="${15:-}"

  if [[ "$node_arg" != "--auto" ]] && is_excluded_node "$node_arg" "$exclude_list"; then
    err "Target node '$node_arg' is excluded by --exclude"
    return 1
  fi

  [[ "$gpu_count" =~ ^[0-9]+$ && "$gpu_count" -ge 1 ]] || {
    err "Invalid GPU count requested: $gpu_count"
    return 1
  }

  input_dir="$(cd "$input_dir" && pwd)" || return 1
  run_script="$(cd "$(dirname "$run_script")" && pwd)/$(basename "$run_script")" || return 1
  output_dir="$(mkdir -p "$output_dir" && cd "$output_dir" && pwd)" || return 1

  [[ -d "$input_dir" ]] || { err "input_dir is not a directory: $input_dir"; return 1; }
  [[ -f "$run_script" ]] || { err "run_script is not a file: $run_script"; return 1; }

  local start_time job_id node_line name user host env_file tags target setup_out rc remote_dir work_dir gpu_ids local_job_dir

  start_time="$(date +%Y%m%d-%H%M%S)"

  if [[ -n "$job_id_override" ]]; then
    job_id="$job_id_override"
  elif [[ "$array_task" != "-" ]]; then
    job_id="slerb-${start_time}-$$-task${array_task}"
  else
    job_id="slerb-${start_time}-$$"
  fi

  if [[ "${SLERB_IN_DISPATCH:-no}" != "yes" && "$queue_on_resource" == "yes" ]] && queue_has_jobs; then
    queue_job "$job_id" "$node_arg" "$input_dir" "$run_script" \
      "$output_dir" "$keep" "$detach" "$array_task" "$array_range" \
      "$array_id" "$exclude_list" "$gpu_wanted" "$gpu_count"
    return $?
  fi

  while true; do
    if [[ "$node_arg" == "--auto" ]]; then
      name="$(choose_auto_node "$exclude_list" "$gpu_count" || true)"
      if [[ -z "$name" ]]; then
        if [[ "$wait_seconds" -gt 0 ]]; then
          if [[ -n "$exclude_list" ]]; then
            log_msg "No node with $gpu_count free non-excluded GPU(s) found; excluded=[$exclude_list]; waiting ${wait_seconds}s"
          else
            log_msg "No node with $gpu_count free GPU(s) found; waiting ${wait_seconds}s"
          fi
          sleep "$wait_seconds"
          continue
        fi

        if [[ "$queue_on_resource" == "yes" ]]; then
          queue_job "$job_id" "$node_arg" "$input_dir" "$run_script" \
            "$output_dir" "$keep" "$detach" "$array_task" "$array_range" \
            "$array_id" "$exclude_list" "$gpu_wanted" "$gpu_count"
          return $?
        fi

        if [[ "${SLERB_IN_DISPATCH:-no}" == "yes" ]]; then
          set +e
          return 81
        fi

        if [[ -n "$exclude_list" ]]; then
          err "No node with $gpu_count free non-excluded GPU(s) found; excluded=[$exclude_list]"
        else
          err "No node with $gpu_count free GPU(s) found"
        fi
        return 81
      fi
    else
      name="$node_arg"
    fi

    if ! node_line="$(get_node "$name")"; then
      err "Unknown node: $name"
      return 1
    fi

    IFS=$'\t' read -r name user host env_file tags <<< "$node_line"

    env_file="${env_file:-$DEFAULT_ENV_FILE}"
    target="$(ssh_target "$user" "$host")"

    set +e
    setup_out="$(remote_setup_job \
      "$target" "$env_file" "$job_id" "$gpu_wanted" "$gpu_count" 2>&1)"
    rc=$?
    set -e

    if [[ $rc -eq 0 ]]; then
      break
    fi

    if [[ $rc -eq 61 && "$wait_seconds" -gt 0 ]]; then
      log_msg "$name does not have $gpu_count free GPU(s); waiting ${wait_seconds}s"
      sleep "$wait_seconds"
      continue
    fi

    if [[ $rc -eq 63 && "$wait_seconds" -gt 0 ]]; then
      if [[ -n "$gpu_wanted" ]]; then
        log_msg "$name requested GPU(s) $gpu_wanted not free; waiting ${wait_seconds}s"
      else
        log_msg "$name GPU allocation race or busy GPU(s); waiting ${wait_seconds}s"
      fi
      sleep "$wait_seconds"
      continue
    fi

    if [[ $rc -eq 64 && "$wait_seconds" -gt 0 ]]; then
      log_msg "$name is reserved; waiting ${wait_seconds}s"
      sleep "$wait_seconds"
      continue
    fi

    if is_resource_rc "$rc"; then
      if [[ "$queue_on_resource" == "yes" ]]; then
        queue_job "$job_id" "$node_arg" "$input_dir" "$run_script" \
          "$output_dir" "$keep" "$detach" "$array_task" "$array_range" \
          "$array_id" "$exclude_list" "$gpu_wanted" "$gpu_count"
        return $?
      fi

      if [[ "${SLERB_IN_DISPATCH:-no}" == "yes" ]]; then
        set +e
        return "$rc"
      fi

      err "Remote setup failed on $name: $setup_out"
      return "$rc"
    fi

    if [[ "$node_arg" == "--auto" && "$wait_seconds" -gt 0 ]]; then
      log_msg "Auto node race or setup failure on $name: $setup_out; waiting ${wait_seconds}s"
      sleep "$wait_seconds"
      continue
    fi

    err "Remote setup failed on $name: $setup_out"
    return "$rc"
  done

  remote_dir="$(printf '%s\n' "$setup_out" | kv_get REMOTE_DIR)"
  work_dir="$(printf '%s\n' "$setup_out" | kv_get WORK_DIR)"
  gpu_ids="$(printf '%s\n' "$setup_out" | kv_get GPU_IDS)"
  gpu_ids="${gpu_ids:-$(printf '%s\n' "$setup_out" | kv_get GPU_ID)}"
  local_job_dir="$output_dir/$job_id"

  mkdir -p "$local_job_dir"

  log_msg "Staging $job_id to $name GPU(s) $gpu_ids"

  set +e
  rsync_to_remote "$input_dir/" "$target" "$work_dir/"
  rc=$?

  if [[ $rc -eq 0 ]]; then
    rsync -azcL "$run_script" "$target:$work_dir/run.sh"
    rc=$?
  fi
  set -e

  if [[ $rc -ne 0 ]]; then
    remote_abort_job "$target" "$env_file" "$remote_dir"
    err "Staging failed for $job_id"
    return "$rc"
  fi

  history_record_launch "$job_id" "STAGED" "-" "$name" "$target" \
    "$(date '+%Y-%m-%d %H:%M:%S')" "-" "$local_job_dir" \
    "$remote_dir" "$keep" "$input_dir" "$run_script" "$gpu_ids" \
    "$array_range" "$array_task" "$array_id"

  if [[ "$detach" == "yes" ]]; then
    remote_run_detached "$target" "$env_file" "$remote_dir" "$gpu_ids" "$job_id" "$array_task" "$array_range" "$array_id"
    history_update "$job_id" "DETACHED" "-" "-"
    log_msg "Launched detached: $job_id on $name GPU(s) $gpu_ids"
    printf '%s\n' "$job_id"
    return 0
  fi

  set +e
  remote_run_foreground "$target" "$env_file" "$remote_dir" "$gpu_ids" "$job_id" "$array_task" "$array_range" "$array_id"
  rc=$?
  set -e

  if [[ $rc -eq 0 ]]; then
    history_update "$job_id" "DONE" "$rc" "$(date '+%Y-%m-%d %H:%M:%S')"
  else
    history_update "$job_id" "FAILED" "$rc" "$(date '+%Y-%m-%d %H:%M:%S')"
  fi

  fetch_job "$job_id" "no" || true

  return "$rc"
}

submit_array() {
