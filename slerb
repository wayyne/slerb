remote_cancel_job() {
  local target="$1" remote_dir="$2"

  ssh "${SSH_OPTS[@]}" "$target" bash -s -- "$remote_dir" <<'REMOTE'
set -u

remote_dir="$1"

if [[ ! -d "$remote_dir" ]]; then
  echo "MISSING"
  exit 76
fi

LOCK_DIR=""
LOCK_DIRS=""
if [[ -f "$remote_dir/.slerb_state" ]]; then
  source "$remote_dir/.slerb_state" >/dev/null 2>&1 || true
fi

cleanup_slerb_locks() {
  local dirs="${LOCK_DIRS:-${LOCK_DIR:-}}"
  local dir

  IFS=',' read -ra _slerb_cleanup_lock_dirs <<< "$dirs"

  for dir in "${_slerb_cleanup_lock_dirs[@]}"; do
    [[ -n "$dir" ]] && rm -rf "$dir"
  done
}

{
  grep -v '^STATUS=' "$remote_dir/.slerb_state" 2>/dev/null | \
    grep -v '^END_TIME=' || true
  echo "STATUS=CANCELED"
  echo "END_TIME=$(date -Is)"
} > "$remote_dir/.slerb_state.tmp"

mv "$remote_dir/.slerb_state.tmp" "$remote_dir/.slerb_state"

echo "130" > "$remote_dir/exit_code"

{
  printf '\nSLERB job canceled: %s\n' "$(date -Is)"
} >> "$remote_dir/job.log" 2>/dev/null || true

pid=""
pgid=""

if [[ -s "$remote_dir/pid" ]]; then
  pid="$(cat "$remote_dir/pid" | tr -dc '0-9')"
fi

if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
  pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ')"
fi

job_pids() {
  local self self_pgid wd gpu_uuids

  self="$$"
  self_pgid="$(ps -o pgid= -p "$self" 2>/dev/null | tr -d ' ')"
  wd="${WORK_DIR:-$remote_dir/work}"

  ps -eo pid=,ppid=,pgid=,sid=,cmd= | awk \
    -v rd="$remote_dir" \
    -v wd="$wd" \
    -v self="$self" \
    -v self_pgid="$self_pgid" '
      {
        pid=$1
        ppid=$2
        pgid=$3
        cmd=$0
      }

      pid == self {next}
      ppid == self {next}
      pgid == self_pgid {next}

      cmd ~ /bash -s --/ {next}
      cmd ~ /awk -v rd=/ {next}
      cmd ~ /awk -v wd=/ {next}
      cmd ~ /ps -eo/ {next}

      index(cmd, rd) || index(cmd, wd) {
        print pid
      }
    '

  gpu_uuids="${GPU_UUIDS:-${GPU_UUID:-}}"

  if [[ -n "$gpu_uuids" ]] && command -v nvidia-smi >/dev/null 2>&1; then
    nvidia-smi --query-compute-apps=pid,gpu_uuid \
      --format=csv,noheader,nounits 2>/dev/null | awk -F',' \
      -v uuids="$gpu_uuids" '
        BEGIN {
          n = split(uuids, uuid_list, ",")
          for (i = 1; i <= n; i++) {
            wanted[uuid_list[i]] = 1
          }
        }

        {
          pid=$1
          gpu_uuid=$2

          gsub(/^[[:space:]]+|[[:space:]]+$/, "", pid)
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", gpu_uuid)

          if (wanted[gpu_uuid]) {
            print pid
          }
        }
      '
  fi
}

kill_group() {
  local sig="$1"

  if [[ -n "$pgid" ]]; then
    kill "-$sig" -- "-$pgid" 2>/dev/null || true
  elif [[ -n "$pid" ]]; then
    kill "-$sig" "$pid" 2>/dev/null || true
  fi
}

kill_matches() {
  local sig="$1"
  local pids

  pids="$(job_pids | tr '\n' ' ')"
  [[ -z "$pids" ]] && return 0

  # shellcheck disable=SC2086
  kill "-$sig" $pids 2>/dev/null || true
}

kill_group TERM
kill_matches TERM

for _ in 1 2 3 4 5; do
  sleep 1
  [[ -z "$(job_pids)" ]] && break
done

if [[ -n "$(job_pids)" ]]; then
  kill_group KILL
  kill_matches KILL
  sleep 1
fi

if [[ -n "$(job_pids)" ]]; then
  echo "FAILED_TO_KILL"
  job_pids
  exit 70
fi

cleanup_slerb_locks

echo "CANCELED"
REMOTE
}

remote_reserve_resource() {
  local target="$1" env_file="$2" scope="$3" gpu_wanted="$4" reason="$5"

  ssh "${SSH_OPTS[@]}" "$target" bash -s -- \
    "$env_file" "$scope" "$gpu_wanted" "$reason" <<'REMOTE'
set -euo pipefail

env_file="$1"
scope="$2"
gpu_wanted="${3:-}"
reason="${4:-reserved}"

if [[ -f "$env_file" ]]; then
  source "$env_file"
fi

SLERB_SCRATCH="${SLERB_SCRATCH:-$HOME/slerb}"
SLERB_LOCKS_ROOT="${SLERB_LOCKS_ROOT:-$SLERB_SCRATCH/locks}"

