show_arrays() {
  printf '%-28s %-8s %-8s %-8s %-8s %-8s %s\n' "ARRAY_ID" "TOTAL" "DONE" "FAILED" "RUNNING" "OTHER" "TASKS"

  awk -F'\t' '$16 != "" && $16 != "-" {print $16}' "$JOBS_FILE" | sort -u | while read -r aid; do
    [[ -z "$aid" ]] && continue

    awk -F'\t' -v a="$aid" '
      $16 == a {
        total++;
        tasks = tasks (tasks ? "," : "") $15;
        if ($2 == "DONE") done++;
        else if ($2 == "FAILED" || $2 == "FAIL") failed++;
        else if ($2 == "RUNNING" || $2 == "DETACHED" || $2 == "STAGED") running++;
        else other++;
      }
      END {
        printf "%-28s %-8d %-8d %-8d %-8d %-8d %s\n", a, total+0, done+0, failed+0, running+0, other+0, tasks
      }
    ' "$JOBS_FILE"
  done
}

